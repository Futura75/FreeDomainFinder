# =====================================================================
# FreeDomainFinder — AI provider configuration
# =====================================================================
# Configure at least ONE provider. The AI panel is disabled in the UI
# until at least one provider is correctly configured.
#
# Optional: choose the default provider (otherwise the first configured
# one is used).
# AI_PROVIDER=groq

# ---- Groq (free tier, fast) — https://console.groq.com/keys ----
GROQ_API_KEY=

# ---- OpenAI — https://platform.openai.com/api-keys ----
OPENAI_API_KEY=

# ---- Anthropic — https://console.anthropic.com/settings/keys ----
ANTHROPIC_API_KEY=

# ---- OpenRouter (aggregator, free models available) — https://openrouter.ai/keys ----
OPENROUTER_API_KEY=

# ---- OpenCode GO (self-hosted OpenAI-compatible endpoint) ----
# Requires a base URL, an API key and a model name.
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
OPENCODE_MODEL=

# ---- Together AI (free tier) — https://api.together.xyz/settings/api-keys ----
TOGETHER_API_KEY=

# ---- Mistral — https://console.mistral.ai/api-keys ----
MISTRAL_API_KEY=

# ---- xAI (Grok) — https://console.x.ai ----
XAI_API_KEY=

# ---- Ollama (local, no key) — https://ollama.com ----
# Leave empty to use the default http://localhost:11434/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1
